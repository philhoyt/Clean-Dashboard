{
	"name": "philhoyt/wp-dashboard-cleanup",
	"description": "Removes noise from the WordPress admin dashboard.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"yahnis-elsts/plugin-update-checker": "^5.5"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.10",
		"wp-coding-standards/wpcs": "^3.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"scripts": {
		"post-install-cmd": "@php scripts/copy-puc.php",
		"post-update-cmd": "@php scripts/copy-puc.php",
		"lint": "phpcs",
		"lint:fix": "phpcbf"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
