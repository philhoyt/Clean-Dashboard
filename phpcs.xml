<?xml version="1.0"?>
<ruleset name="Dashboard Cleanup">
	<description>WordPress coding standards for the Dashboard Cleanup plugin.</description>

	<!-- Files to check -->
	<file>dashboard-cleanup.php</file>
	<file>includes/</file>
	<file>scripts/</file>

	<!-- Show progress and sniff codes -->
	<arg value="sp"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>

	<!-- Use WordPress standards -->
	<rule ref="WordPress"/>

	<!-- The build script in scripts/ runs via the Composer CLI before WordPress
	     is loaded, so WP_Filesystem and output escaping do not apply there. -->
	<rule ref="WordPress.WP.AlternativeFunctions">
		<exclude-pattern>scripts/*</exclude-pattern>
	</rule>
	<rule ref="WordPress.Security.EscapeOutput">
		<exclude-pattern>scripts/*</exclude-pattern>
	</rule>

	<!-- Plugin-specific config -->
	<config name="text_domain" value="wp-dashboard-cleanup"/>
	<config name="minimum_supported_wp_version" value="5.5"/>
</ruleset>
