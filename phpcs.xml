<?xml version="1.0"?>
<ruleset name="Dashboard Cleanup">
	<description>WordPress coding standards for the Dashboard Cleanup plugin.</description>

	<!-- Files to check -->
	<file>wp-dashboard-cleanup.php</file>
	<file>includes/</file>

	<!-- Show progress and sniff codes -->
	<arg value="sp"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>

	<!-- Use WordPress standards -->
	<rule ref="WordPress"/>

	<!-- Plugin-specific config -->
	<config name="text_domain" value="wp-dashboard-cleanup"/>
	<config name="minimum_supported_wp_version" value="5.0"/>
</ruleset>
